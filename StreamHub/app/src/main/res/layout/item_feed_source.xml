<?xml version="1.0" encoding="utf-8"?>
<!-- item_feed_source.xml -->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp">

        <!-- Color dot -->
        <View
            android:id="@+id/view_dot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot"
            android:layout_marginEnd="10dp" />

        <!-- Name + URL -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_feed_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_feed_url"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_hint"
                android:textSize="11sp"
                android:maxLines="1"
                android:ellipsize="middle" />

        </LinearLayout>

        <!-- Toggle switch -->
        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_feed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="8dp" />

        <!-- Delete button -->
        <ImageButton
            android:id="@+id/btn_delete_feed"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_delete"
            android:padding="4dp"
            android:contentDescription="Remove feed" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
